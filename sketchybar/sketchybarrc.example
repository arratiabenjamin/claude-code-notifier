#!/usr/bin/env bash
# Minimal SketchyBar config that adds a Claude Code session indicator (transparent pill widget).
#
# This file is an EXAMPLE. If you already have a sketchybarrc, copy ONLY the
# `claude_done` event + `claude` item block at the bottom into your own file.
# The bar / default settings here are sane defaults for users starting fresh.

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Bar 100% transparent — only the items render, no extra grey strip over the macOS menu bar.
sketchybar --bar position=top \
                 height=32 \
                 blur_radius=0 \
                 color=0x00000000 \
                 border_width=0 \
                 sticky=on \
                 topmost=window \
                 padding_left=0 \
                 padding_right=10

# Defaults: clear typography, generous padding so the pill reads well.
sketchybar --default updates=when_shown \
                    icon.font="SF Pro:Bold:13.0" \
                    icon.color=0xffffffff \
                    icon.padding_left=8 \
                    icon.padding_right=4 \
                    label.font="SF Pro:Semibold:12.0" \
                    label.color=0xffffffff \
                    label.padding_left=4 \
                    label.padding_right=8 \
                    background.corner_radius=10 \
                    background.height=22 \
                    background.padding_left=4 \
                    background.padding_right=4

# Custom event triggered by the notifier hooks.
sketchybar --add event claude_done

# Claude item — rounded rectangular pill on the right side.
sketchybar --add item claude right \
           --set claude script="$PLUGIN_DIR/claude.sh" \
                        update_freq=15 \
                        click_script="$PLUGIN_DIR/claude_popup.sh" \
                        icon="◆" \
                        icon.color=0xffffffff \
                        label="0 · 0" \
                        background.color=0xff2e7d32 \
                        background.drawing=on \
                        popup.background.color=0xee1e1e1e \
                        popup.background.corner_radius=10 \
                        popup.background.border_color=0xff444444 \
                        popup.background.border_width=1 \
                        popup.horizontal=off \
           --subscribe claude claude_done

sketchybar --update
